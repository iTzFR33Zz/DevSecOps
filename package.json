{
  "name": "devsecops-sample-app",
  "version": "1.0.0",
  "description": "Application pour le TP CI-CD",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest --runInBand --forceExit --reporters=default --reporters=jest-junit"
  },
  "jest-junit": {
    "outputDirectory": "reports",
    "outputName": "junit.xml",
    "includeConsoleOutput": "true",
    "ancestorSeparator": " › ",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^17.0.0",
    "supertest": "^7.0.0"
  }
}
